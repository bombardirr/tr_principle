# Local API / SPA (.env.local — not committed)
DATABASE_URL=postgres://appzac:appzac@localhost:55432/appzac?sslmode=disable
JWT_SECRET=local-dev-jwt-secret-change-me-32
HTTP_ADDR=:8080
CORS_ORIGIN=http://localhost:5173
BACKUP_DIR=data/backups
# Leave empty in SPA to use Vite proxy /api → 18081
VITE_API_BASE=
# Optional: Grafana URL baked into SPA (prod Dockerfile default https://grafana.appzac.ru)
# VITE_GRAFANA_URL=http://127.0.0.1:3000
# Yandex Metrica (local optional — leave empty to disable)
# VITE_YANDEX_METRIKA_ID=
