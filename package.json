{
  "name": "tr_principle",
  "version": "1.0.0",
  "description": "Веб-CAT для перевода DOCX в браузере с сохранением разметки.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,vue,scss,css,json}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bombardirr/tr_principle.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bombardirr/tr_principle/issues"
  },
  "homepage": "https://github.com/bombardirr/tr_principle#readme",
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@lucide/vue": "^1.24.0",
    "docx-preview": "^0.4.0",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "vue": "^3.5.23",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "sass": "^1.93.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.1",
    "vitest": "^3.2.7",
    "vue-tsc": "^3.1.3"
  }
}
