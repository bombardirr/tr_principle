# Скопируйте в .env.prod на мини-ПК (не коммитить).
# Контейнеры: ${STACK_NAME}-app, ${STACK_NAME}-db
# NPM → http://${STACK_NAME}-app:8080

STACK_NAME=appzac-prod

POSTGRES_USER=appzac
# Только символы, допустимые в user:password URL (латиница/цифры). Кириллица / : @ # % ломают DATABASE_URL.
POSTGRES_PASSWORD=CHANGE_ME_ascii_only
POSTGRES_DB=appzac

# Тот же пароль, что в POSTGRES_PASSWORD — впишите вручную.
DATABASE_URL=postgres://appzac:CHANGE_ME_ascii_only@db:5432/appzac?sslmode=disable

# JWT (HS256). Минимум 32 символа. Сгенерировать: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_replace_with_output_of_openssl_rand_base64_48

# Origin SPA (для CORS с других origin; same-origin через NPM обычно не нужен, но оставляем).
CORS_ORIGIN=https://appzac.ru

# Каталог бэкапов проектов внутри контейнера (volume в compose).
BACKUP_DIR=/data/backups

# Prometheus scrape token for GET /metrics (Bearer). Also admins can open /ops/metrics in the app.
# Generate: openssl rand -hex 32
METRICS_TOKEN=CHANGE_ME_metrics_scrape_token

# Grafana (NPM: grafana.appzac.ru → appzac-prod-grafana:3000; also 127.0.0.1:3000 for SSH).
# Generate: openssl rand -base64 24
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password
GRAFANA_ROOT_URL=https://grafana.appzac.ru
# Optional override for Grafana links
# PROMETHEUS_RETENTION=15d
